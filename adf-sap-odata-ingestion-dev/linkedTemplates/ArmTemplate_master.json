{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-sap-odata-ingestion-dev"
		},
		"ls_adls_gen2_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_adls_gen2'"
		},
		"ls_sap_odata_rest_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_sap_odata_rest'"
		},
		"ls_adls_gen2_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://stphdplatdevcin01.dfs.core.windows.net/"
		},
		"ls_odata_northwind_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://services.odata.org/V2/Northwind/Northwind.svc/"
		},
		"ls_sap_odata_rest_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://sapes5.sapdevcenter.com"
		},
		"ls_sap_odata_rest_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "DEMO"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-sap-odata-ingestion-dev_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_adls_gen2_accountKey": {
						"value": "[parameters('ls_adls_gen2_accountKey')]"
					},
					"ls_sap_odata_rest_password": {
						"value": "[parameters('ls_sap_odata_rest_password')]"
					},
					"ls_adls_gen2_properties_typeProperties_url": {
						"value": "[parameters('ls_adls_gen2_properties_typeProperties_url')]"
					},
					"ls_odata_northwind_properties_typeProperties_url": {
						"value": "[parameters('ls_odata_northwind_properties_typeProperties_url')]"
					},
					"ls_sap_odata_rest_properties_typeProperties_url": {
						"value": "[parameters('ls_sap_odata_rest_properties_typeProperties_url')]"
					},
					"ls_sap_odata_rest_properties_typeProperties_userName": {
						"value": "[parameters('ls_sap_odata_rest_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}